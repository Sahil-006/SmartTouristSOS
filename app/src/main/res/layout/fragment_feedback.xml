<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".FeedbackFragment">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Community Feedback"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share your experience to help other tourists and improve local safety."
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/etFeedbackLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Location (e.g., Shimla, Mall Road)"
        android:inputType="text"/>

    <EditText
        android:id="@+id/etFeedbackMessage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:hint="Write your review or safety tip here..."
        android:inputType="textMultiLine"
        android:gravity="top"/>

    <Button
        android:id="@+id/btnSubmitFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Submit Feedback"/>

</LinearLayout>
